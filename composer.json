{
    "name": "psc-acme/bundle-catalog",
    "description": "Package bundle-catalog for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\BundleCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "carbon/carbon": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/serializer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}